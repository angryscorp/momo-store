# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib
frontend/dist
backend/bin

# Test binary, built with `go test -c`
*.test

# Output of the go coverage tool, specifically when used with LiteIDE
*.out

# Dependency directories
frontend/node_modules
vendor/

# IDEs
.idea/
.vscode/

# macOS
.DS_Store

# Terraform
#   .terraform/ – providers/modules cache
#   *.tfstate*  – state files plus *.tfstate.backup / *.tfstate.lock.info
#   *.tfvars    – variable files (the *.example variants stay)
#   backend.hcl – bucket name + creds for the s3 backend
**/.terraform/
**/*.tfstate*
**/*.tfvars
!**/*.tfvars.example
**/backend.hcl
crash.log
crash.*.log
