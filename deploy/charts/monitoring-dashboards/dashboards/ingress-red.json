{
  "annotations": {"list": []},
  "editable": true,
  "graphTooltip": 1,
  "schemaVersion": 39,
  "tags": ["momo-store", "ingress", "red"],
  "title": "Momo Ingress - R.E.D.",
  "uid": "momo-ingress-red",
  "time": {"from": "now-15m", "to": "now"},
  "refresh": "30s",
  "templating": {
    "list": [
      {
        "name": "namespace",
        "label": "exported_namespace",
        "type": "query",
        "datasource": {"type": "prometheus", "uid": "prometheus"},
        "query": "label_values(nginx_ingress_controller_requests, exported_namespace)",
        "refresh": 2,
        "includeAll": false,
        "multi": false,
        "current": {"text": "staging", "value": "staging"}
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Rate - RPS by backend service",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "fieldConfig": {"defaults": {"unit": "reqps", "min": 0}},
      "options": {"legend": {"displayMode": "table", "calcs": ["mean", "max"]}},
      "targets": [
        {
          "expr": "sum by (exported_service) (rate(nginx_ingress_controller_requests{exported_namespace=~\"$namespace\"}[1m]))",
          "legendFormat": "{{exported_service}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Errors - by status class",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "fieldConfig": {"defaults": {"unit": "reqps", "min": 0}},
      "options": {"legend": {"displayMode": "table", "calcs": ["mean", "max"]}},
      "targets": [
        {
          "expr": "sum by (status) (rate(nginx_ingress_controller_requests{exported_namespace=~\"$namespace\",status=~\"4..|5..\"}[1m]))",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Duration - request percentiles (seconds)",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 8},
      "fieldConfig": {"defaults": {"unit": "s", "min": 0}},
      "options": {"legend": {"displayMode": "table", "calcs": ["mean", "max"]}},
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(nginx_ingress_controller_request_duration_seconds_bucket{exported_namespace=~\"$namespace\"}[5m])))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(nginx_ingress_controller_request_duration_seconds_bucket{exported_namespace=~\"$namespace\"}[5m])))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(nginx_ingress_controller_request_duration_seconds_bucket{exported_namespace=~\"$namespace\"}[5m])))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ]
    }
  ]
}
